        <Param val="response = psychoJS.eventManager.waitKeys()[0];&amp;#10;correct_response = trial[&quot;CORRECT_RESPONSE&quot;];&amp;#10;correct = (response === correct_response);&amp;#10;psychoJS.experiment.addData(&quot;image&quot;, trial[&quot;PICTURE&quot;]);&amp;#10;psychoJS.experiment.addData(&quot;response&quot;, response);&amp;#10;psychoJS.experiment.addData(&quot;correct&quot;, correct);&amp;#10;psychoJS.experiment.nextEntry();&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="# Assuming 'stimuli' is your TrialHandler object&amp;#10;&amp;#10;# Get the participant's response&amp;#10;response = event.waitKeys()[0]&amp;#10;&amp;#10;# Get the correct response from the current trial&amp;#10;correct_response = trial['CORRECT_RESPONSE']&amp;#10;&amp;#10;# Check if the response is correct&amp;#10;correct = (response == correct_response)&amp;#10;&amp;#10;# Save the data&amp;#10;thisExp.addData('image', trial['PICTURE'])&amp;#10;thisExp.addData('response', response)&amp;#10;thisExp.addData('correct', correct)&amp;#10;thisExp.nextEntry()&amp;#10;" valType="extendedCode" updates="constant" name="End Routine"/>
